datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Document {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  createdAt DateTime @default(now())

  chunks    Chunk[]
}

model Chunk {
  id         Int      @id @default(autoincrement())
  content    String
  embedding  Unsupported("vector(768)")

  documentId Int
  document   Document @relation(fields: [documentId], references: [id])
}